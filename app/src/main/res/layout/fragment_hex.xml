<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg" android:padding="16dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="HEX 바이트 입력" android:textSize="11sp" android:textColor="@color/muted"
        android:layout_marginBottom="8dp"/>
    <EditText android:id="@+id/etHex"
        android:layout_width="match_parent" android:layout_height="100dp"
        android:hint="68 0F 0F 68 08 01 78 0F ..."
        android:textColor="@color/text_color" android:background="@drawable/bg_card"
        android:padding="14dp" android:fontFamily="monospace" android:textSize="13sp"
        android:gravity="top" android:inputType="text"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="10dp" android:layout_marginBottom="16dp">
        <Button android:id="@+id/btnParse" android:layout_width="wrap_content" android:layout_height="44dp"
            android:text="파싱" android:textColor="@color/white" android:backgroundTint="@color/accent2"
            style="@style/Widget.MaterialComponents.Button"/>
        <Button android:id="@+id/btnExBasic" android:layout_width="wrap_content" android:layout_height="44dp"
            android:text="기본 예시" android:textColor="@color/accent" android:backgroundTint="@color/panel"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
        <Button android:id="@+id/btnExWarn" android:layout_width="wrap_content" android:layout_height="44dp"
            android:text="경고 예시" android:textColor="@color/yellow" android:backgroundTint="@color/panel"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/tvHexResult"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="HEX를 입력하고 파싱 버튼을 누르세요"
            android:textColor="@color/muted" android:textSize="13sp"
            android:fontFamily="monospace" android:lineSpacingMultiplier="1.6"
            android:padding="16dp" android:background="@drawable/bg_card"/>
    </ScrollView>
</LinearLayout>
